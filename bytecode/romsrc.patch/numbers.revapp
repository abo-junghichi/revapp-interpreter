#ifndef NUMBERS_REVAPP
#define NUMBERS_REVAPP

#include "primitives.revapp"
#include "list.revapp"

(-- numbers --)=

zero=0
(0 one plus)=1
(2 ... 10)=
(=base (=num_list)=
 0 (=self =done =num_list
  (=num (=t)= ((done base mul) num plus) self)
  done num_list) fix
)=numeral
(10 numeral)=decimal

#endif /* NUMBERS_REVAPP*/
